# Скопируйте этот файл в .env и заполните значения

# App
APP_NAME=Smart Room Finder
DEBUG=true

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/smartrooms
DATABASE_URL_SYNC=postgresql://postgres:postgres@db:5432/smartrooms

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Parser
SCHEDULE_URL=https://sarfti.ru/?page_id=20
PARSE_INTERVAL_HOURS=6
PARSER_REQUEST_TIMEOUT=30
PARSER_MAX_RETRIES=3

# CORS (через запятую)
ALLOWED_ORIGINS=["http://localhost:3000"]
