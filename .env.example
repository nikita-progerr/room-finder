# ── Backend (.env в папке backend/) ──────────────────────────────

# Приложение
APP_NAME=Smart Room Finder
APP_VERSION=1.0.0
DEBUG=true

# База данных PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/smartrooms
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/smartrooms

# Redis
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=300

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Парсер
SCHEDULE_URL=https://sarfti.ru/?page_id=20
PARSE_INTERVAL_HOURS=6
PARSER_REQUEST_TIMEOUT=30
PARSER_MAX_RETRIES=3

# CORS (через запятую)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001


# ── Frontend (.env.local в папке frontend/) ───────────────────────

NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
